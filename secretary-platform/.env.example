# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase: Authentication > Providers で Google を有効化
# Redirect URL（Supabase Dashboard > Authentication > URL Configuration）:
#   http://localhost:3000/api/auth/google/callback
#   本番: https://your-domain.vercel.app/api/auth/google/callback
# （旧パス /auth/callback も互換のため残しておくと安全）
# Google Cloud Console の OAuth クライアント ID/Secret は Supabase の Google プロバイダに設定
# （下記 GOOGLE_* は Phase 6 カレンダー連携用。ログインとは別）

# OpenAI (文章校正・議事録・リサーチ用プロンプト生成)
OPENAI_API_KEY=
# 任意: gpt-4o / gpt-4o-mini など（未設定時は gpt-4o-mini）
OPENAI_MODEL=

# Perplexity (Webリサーチ)
PERPLEXITY_API_KEY=

# AssemblyAI (音声文字起こし)
ASSEMBLYAI_API_KEY=

# Supabase Storage バケット名（議事録の音声ファイル。Dashboard で作成）
SUPABASE_AUDIO_BUCKET=meeting-audio

# Google Calendar API（ログインとは別スコープ。Phase 6）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# App URL (Vercel production / local)
NEXT_PUBLIC_APP_URL=http://localhost:3000
